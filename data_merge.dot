digraph G {
    node [shape=box, style="filled,rounded", fontname="Tinos", fontsize=14, margin="0.2,0.1"];
    edge [fontname="Tinos", fontsize=12, color="#666666"];
    rankdir=TB;
    splines=ortho;

    subgraph cluster_0 {
        label = "Các Nguồn Dữ Liệu (4 Bộ Kaggle)";
        fontname="Tinos-Bold"; style="dashed"; color="#0288d1"; bgcolor="#e1f5fe";
        A1 [label="Bộ 1: phngnguynthu\nCột: content\nNhãn: Tên file", fillcolor="#ffffff", color="#0288d1"];
        A2 [label="Bộ 2: chuynvinquc\nCột: post_message\nNhãn: label=1", fillcolor="#ffffff", color="#0288d1"];
        A3 [label="Bộ 3: pbl7\nCột: Maintext\nNhãn: Label=1", fillcolor="#ffffff", color="#0288d1"];
        A4 [label="Bộ 4: medical\nCột: content\nNhãn: is_fake", fillcolor="#ffffff", color="#0288d1"];
    }

    subgraph cluster_1 {
        label = "Tiền Xử Lý (Standardization)";
        fontname="Tinos-Bold"; style="dashed"; color="#f57c00"; bgcolor="#fff3e0";
        B1 [label="Trích xuất 'content'\nÁnh xạ nhãn True/False", fillcolor="#ffffff", color="#f57c00"];
        B2 [label="Trích xuất 'post_message'\nÁnh xạ nhãn True/False", fillcolor="#ffffff", color="#f57c00"];
        B3 [label="Trích xuất 'Maintext'\nÁnh xạ nhãn True/False", fillcolor="#ffffff", color="#f57c00"];
        B4 [label="Trích xuất 'content'\nGiữ nguyên nhãn", fillcolor="#ffffff", color="#f57c00"];
    }

    subgraph cluster_2 {
        label = "Hợp Nhất và Làm Sạch (Data Cleansing Pipeline)";
        fontname="Tinos-Bold"; style="dashed"; color="#c2185b"; bgcolor="#fce4ec";
        C [label="Hợp nhất (Concatenate)\nvề một định dạng 11 cột chuẩn", fillcolor="#ffffff", color="#c2185b"];
        D [label="Chuẩn hóa Text\n(Xóa khoảng trắng thừa)", fillcolor="#ffffff", color="#c2185b"];
        E [label="Lọc chiều dài\n(Loại bỏ bài < 20 ký tự)", fillcolor="#ffffff", color="#c2185b"];
        F [label="Xử lý xung đột nhãn (Conflict)\n(Bỏ các bài trùng nội dung nhưng khác nhãn)", fillcolor="#ffffff", color="#c2185b"];
        G [label="Xóa trùng lặp (Deduplication)\n(Chỉ giữ lại 1 bản ghi duy nhất)", fillcolor="#ffffff", color="#c2185b"];
    }

    H [label="Dữ liệu Lớn Hợp Nhất\n(merged_fake_news_dataset.csv)", style="filled,rounded", fillcolor="#e8f5e9", color="#388e3c", fontname="Tinos-Bold", fontsize=16];

    A1 -> B1;
    A2 -> B2;
    A3 -> B3;
    A4 -> B4;

    B1 -> C;
    B2 -> C;
    B3 -> C;
    B4 -> C;

    C -> D -> E -> F -> G;
    G -> H [color="#388e3c", penwidth=2];
}
