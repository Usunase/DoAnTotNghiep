<?xml version="1.0" encoding="UTF-8"?>
<mxfile version="21.1.2">
  <diagram id="shieldai_algo" name="Algorithm Design">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" background="#ffffff" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Input -->
        <mxCell id="Input" value="Văn bản Đầu vào&#10;(Tiêu đề &amp; Nội dung)" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="320" y="40" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- Pipeline Tiền xử lý -->
        <mxCell id="Group_Preprocess" value="Đường ống Tiền xử lý (Preprocessing)" style="swimlane;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;startSize=30;" vertex="1" parent="1">
          <mxGeometry x="120" y="140" width="240" height="260" as="geometry" />
        </mxCell>
        <mxCell id="Prep_Clean" value="Làm sạch Văn bản&#10;(Xóa URL, chữ thường)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;" vertex="1" parent="Group_Preprocess">
          <mxGeometry x="40" y="50" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="Prep_PyVi" value="PyVi Tokenizer&#10;(Nối từ ghép Tiếng Việt)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;" vertex="1" parent="Group_Preprocess">
          <mxGeometry x="40" y="130" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="Prep_PhoBERT" value="PhoBERT BPE Tokenizer&#10;(Padding &amp; Truncation 256)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;" vertex="1" parent="Group_Preprocess">
          <mxGeometry x="40" y="200" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="E_P1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;" edge="1" parent="Group_Preprocess" source="Prep_Clean" target="Prep_PyVi">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="E_P2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;" edge="1" parent="Group_Preprocess" source="Prep_PyVi" target="Prep_PhoBERT">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Pipeline Giải thích -->
        <mxCell id="Group_XAI" value="Động cơ Giải thích (XAI)" style="swimlane;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;startSize=30;" vertex="1" parent="1">
          <mxGeometry x="460" y="140" width="240" height="260" as="geometry" />
        </mxCell>
        <mxCell id="XAI_Upper" value="Đo lường viết hoa&#10;(&gt;50% cảnh báo đỏ)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;" vertex="1" parent="Group_XAI">
          <mxGeometry x="40" y="50" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="XAI_Punc" value="Đo lường dấu câu&#10;(Lạm dụng !!! ???)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;" vertex="1" parent="Group_XAI">
          <mxGeometry x="40" y="130" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="XAI_Words" value="Từ khóa giật gân&#10;(Sốc, kinh hoàng, ...)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;" vertex="1" parent="Group_XAI">
          <mxGeometry x="40" y="200" width="160" height="50" as="geometry" />
        </mxCell>

        <!-- Model Deep Learning -->
        <mxCell id="Group_Model" value="Mạng Nơ-ron Học sâu (Deep Learning Model)" style="swimlane;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;startSize=30;" vertex="1" parent="1">
          <mxGeometry x="120" y="440" width="240" height="260" as="geometry" />
        </mxCell>
        <mxCell id="Model_Base" value="PhoBERT Base&#10;(12 Transformer Layers)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;fontStyle=1" vertex="1" parent="Group_Model">
          <mxGeometry x="40" y="50" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="Model_CLS" value="Trích xuất Vector [CLS]&#10;(768 chiều)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;" vertex="1" parent="Group_Model">
          <mxGeometry x="40" y="130" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="Model_MLP" value="Sequence Classification Head&#10;(MLP + Dropout)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;" vertex="1" parent="Group_Model">
          <mxGeometry x="30" y="200" width="180" height="50" as="geometry" />
        </mxCell>
        <mxCell id="E_M1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;" edge="1" parent="Group_Model" source="Model_Base" target="Model_CLS">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="E_M2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;" edge="1" parent="Group_Model" source="Model_CLS" target="Model_MLP">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Softmax Output -->
        <mxCell id="Softmax" value="Hàm Softmax&#10;(Quy chuẩn Xác suất 0-100%)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="150" y="740" width="180" height="80" as="geometry" />
        </mxCell>

        <!-- Kết hợp (Aggregation) -->
        <mxCell id="Final_JSON" value="JSON Phản hồi (API Response)&#10;1. Nhãn: Tin thật / Tin giả&#10;2. Confidence Score (%)&#10;3. Giải thích Heuristics" style="shape=document;whiteSpace=wrap;html=1;boundedLbl=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="310" y="860" width="200" height="100" as="geometry" />
        </mxCell>

        <!-- Các kết nối chéo -->
        <!-- Input to Preprocess -->
        <mxCell id="E_In_Prep" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="Input" target="Group_Preprocess">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Input to XAI -->
        <mxCell id="E_In_XAI" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="Input" target="Group_XAI">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        
        <!-- Preprocess to Model -->
        <mxCell id="E_Prep_Model" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="Group_Preprocess" target="Group_Model">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Model to Softmax -->
        <mxCell id="E_Model_Soft" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="Group_Model" target="Softmax">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Softmax to Final -->
        <mxCell id="E_Soft_Final" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="Softmax" target="Final_JSON">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="240" y="840" />
              <mxPoint x="410" y="840" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- XAI to Final -->
        <mxCell id="E_XAI_Final" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;entryX=0.5;entryY=0;entryDx=0;entryDy=0;dashed=1;" edge="1" parent="1" source="Group_XAI" target="Final_JSON">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="580" y="840" />
              <mxPoint x="410" y="840" />
            </Array>
          </mxGeometry>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
